# Frontend variables (with VITE_ prefix)
VITE_OPENWEATHER_API_KEY=your_openweather_api_key
VITE_ORS_API_KEY=your_openrouteservice_api_key
VITE_API_BASE_URL=http://localhost:3000
VITE_COHERE_API_KEY=your_cohere_api_key

# Backend variables (without VITE_ prefix)
OPENWEATHER_API_KEY=your_openweather_api_key
ORS_API_KEY=your_openrouteservice_api_key
API_BASE_URL=http://localhost:3000
COHERE_API_KEY=your_cohere_api_key
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret

# Additional API Keys
OPENAI_KEY=your_openai_api_key
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Server Configuration
PORT=3000

# Pip digital agent controls
PIP_AGENT_ENABLED=false
PIP_AGENT_CRON=*/1 * * * *
PIP_AGENT_MAX_TRIPS_PER_RUN=2
PIP_AGENT_DELAY_BETWEEN_TRIPS_MS=120000
# Frontend polling interval (30 seconds = 30000ms)
VITE_PIP_POLL_INTERVAL_MS=30000

# Firestore quota management (set USE_FIRESTORE=false to stop Firestore reads)
USE_FIRESTORE=true
OPPORTUNITIES_CACHE_TTL_MS=120000
MAX_OPPORTUNITIES_PER_USER=20

# Firebase Configuration (for backend)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_service_account_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Cloudinary Configuration (optional)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
